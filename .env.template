# Azure OpenAI Configuration
# Copy this file to .env and fill in your actual values

# Required: Azure OpenAI credentials
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Optional: Azure OpenAI model deployments (defaults will be used if not set)
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Optional: Alternative providers (uncomment if using)
# AI_PROVIDER=azure
# OPENAI_API_KEY=your-openai-api-key
# GITHUB_TOKEN=your-github-token

# Optional: RAG system parameters
# RAG_TOP_K=3
# RAG_SIMILARITY_THRESHOLD=0.7

# Optional: LLM client settings
# AI_MAX_TOKENS=1000
# AI_TEMPERATURE=0.7
# AI_STREAM=false
# AI_PERSIST_CHAT_HISTORY=true